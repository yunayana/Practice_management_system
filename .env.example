# ============================================================
# Szablon zmiennych środowiskowych – skopiuj jako .env
# i uzupełnij prawdziwymi wartościami.
# NIE commituj pliku .env do repozytorium!
# ============================================================

# ── Bezpieczeństwo ────────────────────────────────────────────────────────────
# Wygeneruj losowy klucz: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=zmien-na-losowy-klucz-minimum-32-znaki

# ── Baza danych ───────────────────────────────────────────────────────────────
# SQLite (lokalne dev) – domyślnie tworzony jako praktyki.db w katalogu app.py
# DATABASE_URL=sqlite:///praktyki.db
# MariaDB (produkcja):
# DATABASE_URL=mysql+pymysql://user:password@localhost/praktyki

# ── Microsoft Entra ID / Azure AD ─────────────────────────────────────────────
# Zarejestruj aplikację na: https://portal.azure.com → Entra ID → App registrations
MICROSOFT_CLIENT_ID=twoj-client-id-z-azure
MICROSOFT_CLIENT_SECRET=twoj-client-secret-z-azure
# Tenant: "common" (wszystkie org), lub konkretny tenant UUID
MICROSOFT_TENANT_ID=common
# Musi być identyczny z Redirect URI w rejestracji aplikacji Azure
MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/callback/microsoft

# ── Domeny organizacyjne ──────────────────────────────────────────────────────
# Użytkownicy z STUDENT_EMAIL_DOMAIN → rola student (konto od razu aktywne)
# Użytkownicy z STAFF_EMAIL_DOMAIN   → rola opiekun_uczelniany (wymaga zatwierdzenia)
# Inne domeny → odmowa dostępu
STUDENT_EMAIL_DOMAIN=student.ans.edu.pl
STAFF_EMAIL_DOMAIN=ans.edu.pl
